{
  "projectType": "saas",
  "projectName": "Hermes Labyrinth",
  "projectDescription": "A read-only observability dashboard plugin for Hermes Agent that maps autonomous sessions as journeys through crossings, tools, skills, cron jobs, and model transitions.",
  "theme": "luma",
  "primaryColor": "#4a6fa5",
  "lightColor": "#ece7d6",
